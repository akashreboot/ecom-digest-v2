# Streamlit secrets for the Ecom Digest dashboard
#
# ─── How to use this file ───────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT
#   1. Copy this file to `.streamlit/secrets.toml` (same directory, drop the
#      `.example` suffix).
#   2. Replace the placeholder below with your real Anthropic API key.
#   3. The real `secrets.toml` is gitignored — it will never be committed.
#
# STREAMLIT COMMUNITY CLOUD (https://share.streamlit.io)
#   1. Do NOT commit your real secrets.toml.
#   2. In the Streamlit Cloud UI for this app: Settings → Secrets.
#   3. Paste the exact same TOML contents (key = "value" format) and save.
#      Streamlit Cloud will expose them via `st.secrets["ANTHROPIC_API_KEY"]`
#      AND as the environment variable `ANTHROPIC_API_KEY` automatically.
#
# PRECEDENCE (what dashboard.py uses)
#   1. `os.environ["ANTHROPIC_API_KEY"]`        — wins if already set
#   2. `st.secrets["ANTHROPIC_API_KEY"]`        — local secrets.toml or Cloud
#   3. `.env` file (legacy local-dev path)      — falls back to this
#   If none are set, the dashboard runs in "demo mode" and uses the
#   deterministic template fallback in section 6.

ANTHROPIC_API_KEY = "your_api_key_here"
